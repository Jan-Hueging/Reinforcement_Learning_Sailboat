    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/sail.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0 0.0 1.175"/>
      <mass value="3.0"/>
      <inertia ixx="1.3806250000000002" ixy="0.0" ixz="0.0" iyy="1.93517456994115" iyz="0.0" izz="0.5545495699411498"/>
    </inertial>
  </link>
  <!-- =================================================================== -->
  <!-- 5. Das Ruder (Rudder)                                              -->
  <!-- =================================================================== -->
  <joint name="rudder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rudder_link"/>
    <origin rpy="0 0 0" xyz="-0.988233 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <!-- Das Ruder benötigt Stellkraft (effort), um die Position gegen den Wasserdruck zu halten -->
    <limit effort="50" lower="-0.78" upper="0.78" velocity="1.5"/>
  </joint>
  <link name="rudder_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
