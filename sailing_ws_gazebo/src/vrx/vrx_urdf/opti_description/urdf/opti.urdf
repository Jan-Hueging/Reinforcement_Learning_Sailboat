<robot name="opti">

  <material name="default_gray">
    <color rgba="0.8 0.8 0.8 1"/>
  </material>

  <!-- in Metern -->
  <!-- Wie tief reicht der Kiel unter das Boot -->
  <!-- Segelfläche in m² -->
  <!-- =================================================================== -->
  <!-- 2. Der Hauptrumpf (Base Link)                                      -->
  <!-- =================================================================== -->
  <link name="base_link">
    <!-- Visuelle Darstellung im Simulator -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/boat.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="default_gray"/>
    </visual>
    <!-- Kollisionsmodell: Nutzt exakt dieselbe Geometrie -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://opti_description/share/opti_description/meshes/boat.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <!-- Trägheitseigenschaften -->
    <inertial>
      <!-- Tipp: Den Schwerpunkt (origin) bei einem echten Rumpf leicht nach hinten/unten verschieben -->
      <origin rpy="0 0 0" xyz="-0.1 0.0 -0.1"/>
      <mass value="35.0"/>
      <inertia ixx="6.640958333333331" ixy="0.0" ixz="0.0" iyy="18.34583333333333" iyz="0.0" izz="19.15345833333333"/>
    </inertial>
  </link>
  <!-- =================================================================== -->
  <!-- 3. Der Kiel (Keel)                                                 -->
  <!-- =================================================================== -->
  <joint name="kiel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="kiel_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 -0.5"/>
  </joint>
  <link name="kiel_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.5"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/keel.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="default_gray"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.5"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/keel.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0 0.0 -0.4"/>
      <mass value="25.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="0.2"/>
    </inertial>
  </link>
  <!-- =================================================================== -->
  <!-- 4. Das Segel (Sail)                                                -->
  <!-- =================================================================== -->
  <joint name="sail_joint" type="revolute">
    <parent link="base_link"/>
    <child link="sail_link"/>
    <origin rpy="0 0 0" xyz="0.99628 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <!-- Wichtig: Gelenkreibung gegen Null setzen (dynamics damping="0.0"), damit es sich frei im Wind bewegt -->
    <dynamics damping="0.01" friction="0.0"/>
    <!-- Initiale Limits für die maximale Öffnung (wird über das Plugin überschrieben) -->
    <limit effort="0.0" lower="-1.57" upper="1.57" velocity="2.0"/>
  </joint>
  <link name="sail_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/sail.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="default_gray"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/sail.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0 0.0 1.175"/>
      <mass value="3.0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <!-- =================================================================== -->
  <!-- 5. Das Ruder (Rudder)                                              -->
  <!-- =================================================================== -->
  <joint name="rudder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rudder_link"/>
    <origin rpy="0 0 0" xyz="-0.988233 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <!-- Das Ruder benötigt Stellkraft (effort), um die Position gegen den Wasserdruck zu halten -->
    <limit effort="50" lower="-0.78" upper="0.78" velocity="1.5"/>
  </joint>
  <link name="rudder_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/rudder.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="default_gray"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <!-- Ersetze 'dein_boot_paket' durch den Namen deines ROS-Packages -->
        <mesh filename="package://opti_description/share/opti_description/meshes/rudder.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>
  <!-- =================================================================== -->
  <!-- 6. VRX & Gazebo Plugins                                            -->
  <!-- =================================================================== -->
  <gazebo>
    <!-- 6a. Original-Plugins (Auftrieb & Hydrodynamik Rumpf) -->

    <!-- 6b. Aerodynamik für das Segel -->
    <plugin filename="libgz-sim-lift-drag-system.so" name="gz::sim::systems::LiftDrag">
      <link_name>sail_link</link_name>
      <air_density>1.204</air_density>
      <area>3.5</area>
      <a0>0.0</a0>
      <cla>4.75</cla>
      <cda>0.60</cda>
      <alpha_stall>0.33</alpha_stall>
      <cla_stall>-2.0</cla_stall>
      <cda_stall>0.0</cda_stall>
      <cp>0.0 0.0 1.175</cp>
      <forward>1 0 0</forward>
      <up>0 1 0</up>
    </plugin>
    <!-- Hydrodynamik für das Ruder -->
    <plugin filename="libgz-sim-lift-drag-system.so" name="gz::sim::systems::LiftDrag">
      <link_name>rudder_link</link_name>
      <air_density>1000.0</air_density>
      <area>0.06</area>
      <a0>0.0</a0>
      <cla>4.0</cla>
      <cda>0.5</cda>
      <alpha_stall>0.4</alpha_stall>
      <cla_stall>-1.5</cla_stall>
      <cda_stall>0.0</cda_stall>
      <cp>0.0 0.0 0.0</cp>
      <forward>1 0 0</forward>
      <up>0 1 0</up>
    </plugin>
    <!-- =================================================================== -->
    <!-- 7. AKTIVE STEUERUNGSPLUGINS (NEU)                                   -->
    <!-- =================================================================== -->
    <!-- 7a. RUDER-STEUERUNG: Positionsregler -->
    <!-- Erklaerung: Nimmt einen Winkel (in Radiant) auf dem Topic 'rudder_pos' entgegen -->
    <!-- und steuert den rudder_joint ueber einen internen PID-Regler aktiv an. -->
    <plugin filename="libgz-sim-joint-position-controller-system.so" name="gz::sim::systems::JointPositionController">
      <joint_name>rudder_joint</joint_name>
      <topic>rudder_pos</topic>
      <p_gain>100.0</p_gain>
      <i_gain>1.0</i_gain>
      <d_gain>5.0</d_gain>
    </plugin>
    <!-- 7b. SEGEL-STEUERUNG (SCHOT): Dynamische Gelenk-Limits -->
    <!-- Erklaerung: Dieses Plugin hoert auf das Topic 'sail_pos'. Es bewegt das Segel nicht, -->
    <!-- sondern setzt das obere und untere Limit des sail_joint dynamisch auf +/- den empfangenen Wert. -->
    <!-- Schickst du z.B. 0.5 (ca. 30 Grad), wird das Limit auf [-0.5, 0.5] gesetzt. -->
    <plugin filename="libSailLimitPlugin.so"
        name="gz::sim::systems::SailLimitPlugin">
      <joint_name>sail_joint</joint_name>
      <topic>/sail_pos</topic>
      <max_rate>0.3</max_rate>
    </plugin>
  </gazebo>
</robot>
